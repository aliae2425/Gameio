{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "rootDir": "..",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@skull-king/*": ["../client/src/games/skull-king/game/*"],
      "@love-letter/*": ["../client/src/games/love-letter/game/*"]
    }
  },
  "include": [
    "src",
    "../client/src/games/skull-king/game",
    "../client/src/games/love-letter/game"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "esm": false
  }
}
