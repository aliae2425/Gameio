{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@game/*": ["../client/src/game/*"]
    }
  },
  "include": ["src", "../client/src/game"],
  "ts-node": {
    "require": ["tsconfig-paths/register"],
    "esm": false
  }
}
